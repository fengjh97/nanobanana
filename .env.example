# 必需的环境变量
# Google Generative AI API 密钥 (从 https://aistudio.google.com/app/apikey 获取)
GOOGLE_API_KEY=your_google_api_key_here

# Flask Session 密钥 (用于加密 session，请使用随机字符串)
FLASK_SECRET=your_random_secret_key_here

# 应用登录密码
APP_PASSWORD=your_app_password_here

# 可选的 Supabase 环境变量 (如果不配置，应用会使用本地 SQLite 存储)
# Supabase 项目 URL
SUPABASE_URL=

# Supabase Service Role Key
SUPABASE_SERVICE_ROLE_KEY=

# Supabase 存储桶名称 (默认值如下)
SUPABASE_BUCKET_INPUTS=nanobanana-inputs
SUPABASE_BUCKET_OUTPUTS=nanobanana-outputs

# 服务端口 (默认 8000)
PORT=8000
